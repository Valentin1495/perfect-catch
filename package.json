{
  "name": "perfect-catch",
  "version": "1.0.0",
  "scripts": {
    "build": "cp index.html dist/",
    "dev": "live-server --host=0.0.0.0 --port=5173 --no-browser --watch=index.html",
    "ip": "sh -c 'ipconfig getifaddr en0 || ipconfig getifaddr en1'",
    "sync": "npx cap sync",
    "sync:ios": "npx cap sync ios",
    "sync:android": "npx cap sync android",
    "ios": "npx cap open ios",
    "android": "npx cap open android"
  },
  "dependencies": {
    "@capacitor/android": "^7.4.4",
    "@capacitor/core": "^7.4.4",
    "@capacitor/haptics": "^7.0.1",
    "@capacitor/ios": "^7.4.4"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.4.4",
    "live-server": "^1.2.2"
  }
}